{
  "assembly_guid": "C4F97974-1D9C-4E89-8257-8A139637E51F",
  "name": "Audit Bitlocker / TPM Status [WIN]",
  "description": "Reports TPM readiness and BitLocker status for fixed disks.",
  "type": "powershell",
  "script": "",
  "timeout_seconds": 3600,
  "variables": [
    {
      "name": "CheckAllFixedDisks",
      "label": "Check All Fixed Disks",
      "type": "string",
      "default": true,
      "required": true,
      "description": "Controls whether the script audits all fixed local disks or only the system drive. When false, it checks only $env:SystemDrive, usually C:."
    },
    {
      "name": "IncludeRecoveryKeys",
      "label": "Include Recovery Keys",
      "type": "string",
      "default": "true",
      "required": true,
      "description": "Controls whether BitLocker recovery passwords are printed in console output when available. Use carefully because this exposes sensitive recovery data in script output/logs."
    }
  ],
  "files": []
}
