{
  "assembly_guid": "2B9E8AAB-0FC5-42A0-A030-D486FF6ED7EF",
  "name": "Audit Inactive Domain Users/Computers",
  "description": "Audit either inactive computers or users (or both) on the domain controller that this script is ran against.   Ignorelists for users and computers can be configured as well as adjusting the scope to only audit users, or only audit computers.",
  "type": "powershell",
  "script": "",
  "timeout_seconds": 3600,
  "variables": [
    {
      "name": "audit_scope",
      "label": "Scope of the Audit",
      "type": "string",
      "default": "both",
      "required": true,
      "description": "Scope of the audit, can be \"both\", \"users\", or \"computers\"."
    },
    {
      "name": "user_inactiveDays",
      "label": "Inactive Days for Users",
      "type": "string",
      "default": "30",
      "required": true,
      "description": "Number of days since user was seen active in active directory."
    },
    {
      "name": "user_ignorelist",
      "label": "Users to Ignore When Auditing",
      "type": "string",
      "default": "",
      "required": false,
      "description": "Comma-separated list of users to ignore (e.g. \"userA,userB,userC\") (Do not put quotes)"
    },
    {
      "name": "computer_inactiveDays",
      "label": "Inactive Days for Computers",
      "type": "string",
      "default": "30",
      "required": true,
      "description": "Number of days since computer was seen active in active directory."
    },
    {
      "name": "computer_ignorelist",
      "label": "Computers to Ignore When Auditing",
      "type": "string",
      "default": "",
      "required": false,
      "description": "Comma-separated list of computers to ignore (e.g. \"computerA,computerB,computerC\") (Do not write quotes)"
    }
  ],
  "files": []
}
