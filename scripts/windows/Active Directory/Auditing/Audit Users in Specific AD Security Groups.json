{
  "assembly_guid": "878cfcf8-654e-490b-a4ad-bc955b7d4091",
  "name": "Audit Users in Specific AD Security Groups [WIN]",
  "description": "Used to generate CSV reports of active directory domain users that belong to a specific comma-separated list of AD security groups. ",
  "type": "powershell",
  "script": "",
  "timeout_seconds": 3600,
  "variables": [
    {
      "name": "targetGroups",
      "label": "Groups to Audit",
      "type": "string",
      "default": "\"groupA,groupB,groupC\"",
      "required": true,
      "description": "Name of AD Security Groups (do not add spaces). "
    },
    {
      "name": "CSV_export_path",
      "label": "CSV Report Path",
      "type": "string",
      "default": "C:\\Scripts\\audit_users_in_specific_AD_group_report.csv",
      "required": true,
      "description": "Location to save CSV report data."
    }
  ],
  "files": []
}
