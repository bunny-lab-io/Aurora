{
  "assembly_guid": "121dd824-0336-44f6-90ae-e5bc203a8474",
  "name": "Remotely Update Linux Borealis Agent",
  "description": "Connects to remotely targeted device(s) via SSH and updates the Borealis Agent using the bootstrapper script with preconfigured serverURL and enrollment code at runtime.",
  "type": "ansible",
  "script": "",
  "timeout_seconds": 3600,
  "variables": [
    {
      "name": "bootstrap_url",
      "label": "Bootstrap URL",
      "type": "string",
      "default": "https://raw.githubusercontent.com/bunny-lab-io/Borealis/refs/heads/main/bootstrap.sh",
      "required": true,
      "description": "Declare where the bootstrap script is located remotely."
    },
    {
      "name": "server_url",
      "label": "Borealis Engine URL",
      "type": "string",
      "default": "https://192.168.3.252:5000",
      "required": true,
      "description": "The FQDN / IP URL to the Borealis engine."
    },
    {
      "name": "enrollment_code",
      "label": "Enrollment Code",
      "type": "string",
      "default": "044C-30BA-A742-8D8E-20FB-771A-A94F-E6E4",
      "required": true,
      "description": "Site-specific enrollment code to be used by the agent."
    }
  ],
  "files": []
}
